# ── Vercel Environment Variables ─────────────────────────
# Set these in Vercel Dashboard (Settings → Environment Variables)

# Backend URL for the frontend API calls
# When deployed on Vercel monorepo, the API is on the same domain
# VITE_API_BASE_URL=

# Backend settings (set in Vercel → your-project → Settings → Environment Variables)
# APP_ENV=production
# DEBUG=False
# SECRET_KEY=generate-a-random-secret-key
# CORS_ORIGINS=https://your-project.vercel.app
# OPENWEATHER_API_KEY=your-openweather-api-key
