# ══════════════════════════════════════
# AgriVision AI — Environment Variables
# ══════════════════════════════════════

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agrivision
SQLITE_URL=sqlite+aiosqlite:///./agrivision.db

# OpenWeatherMap
OPENWEATHER_API_KEY=your_api_key_here

# Model
MODEL_PATH=ml/models/efficientnet_b3_crop_disease.h5
TFLITE_MODEL_PATH=ml/models/crop_disease.tflite
USE_TFLITE=false

# App
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File storage
UPLOAD_DIR=uploads
GRADCAM_DIR=gradcam_outputs
REPORTS_DIR=reports
